{
  "name": "sithr",
  "version": "1.0.0",
  "private": true,
  "description": "SIT-HR Advisory — AI-powered HR guidance for adult social care",
  "scripts": {
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "start": "node server/dist/index.js",
    "build:server": "tsc -p server/tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.49.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "react-helmet-async": "^3.0.0",
    "resend": "^6.10.0",
    "rss-parser": "^3.13.0",
    "stripe": "^15.12.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
